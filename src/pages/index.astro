---
import { getEntry, getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import Author from '@/components/ui/Author.astro';
import { DEFAULT_CONFIGURATION } from '@/lib/constants';
import WorkExperience from '@/components/ui/WorkExperience.astro';
import PublicationItem from '@/components/ui/PublicationItem.astro';
import Talk from '@/components/ui/Talk.astro';
import { formatDate, sortByDateRange, sortByYear } from '@/lib/utils';
import { getSiteConfig } from '@/lib/config';
import { getPublications, getWorkExperience } from '@/lib/data';

const entry = await getEntry('pages', 'homepage');

if (!entry) {
  throw new Error('Homepage entry not found');
}

const { Content } = await render(entry);

const links = await getCollection('links');
const emailLink = links.find(
  (link) =>
    link.data.label.toLowerCase() === 'email' ||
    link.data.url.toLowerCase().startsWith('mailto:'),
);
const contactLinks = links.filter((link) => link !== emailLink);

const jobs = getWorkExperience();
const sortedJobs = sortByDateRange(jobs);

const talks = await getCollection('talks');
const sortedTalks = sortByYear(talks);

const news = await getCollection('news');
const splitBoldSegments = (value: string) =>
  value.split('**').map((text, index) => ({
    text,
    bold: index % 2 === 1,
  }));

const sortedNews = [...news].sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const sortedContactLinks = [...contactLinks].sort((a, b) => {
  const aIsCv = a.data.label.toLowerCase() === 'cv' || a.data.url === '/cv';
  const bIsCv = b.data.label.toLowerCase() === 'cv' || b.data.url === '/cv';
  if (aIsCv === bIsCv) return 0;
  return aIsCv ? -1 : 1;
});

const publications = getPublications();
const selectedPublications = publications.filter((pub) => pub.selected);

const config = getSiteConfig();
---

<BaseLayout seo={entry.data.seo}>
  {config.elements.avatar && (
    <Container as="section" class="py-6">
      <Author
        {...DEFAULT_CONFIGURATION.author}
        emailLabel={emailLink?.data.name}
        emailUrl={emailLink?.data.url}
        contactLinks={sortedContactLinks.map((link) => link.data)}
      />
    </Container>
  )}

  {config.sections.about && (
    <Container as="section" class="py-6">
      <div class="flex flex-col gap-6">
        <div class="flex items-center">
          <span class="text-headings text-lg font-semibold">About</span>
        </div>
        <div class="prose prose-base max-w-none dark:prose-invert">
          <Content />
        </div>
      </div>
    </Container>
  )}
  {
    config.sections.news && (
      <Container as="section" class="py-8">
        <div class="flex flex-col gap-5">
          <span class="text-headings text-lg font-semibold">News</span>
          {sortedNews.length === 0 ? (
            <p class="text-muted-foreground">No news yet.</p>
          ) : (
            <div class="max-h-80 overflow-y-auto pr-2">
              <ul class="flex flex-col gap-3">
                {sortedNews.map((item) => (
                  <li class="py-0.5">
                    <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-5">
                      <span class="min-w-28 text-muted-foreground text-xs font-semibold">
                        {formatDate(item.data.date)}
                      </span>
                      {item.data.url ? (
                        <a
                          class="text-headings text-sm hover:text-headings/80 transition-colors"
                          rel="noopener noreferrer"
                          target="_blank"
                          href={item.data.url}
                        >
                          {splitBoldSegments(item.data.title).map((part) =>
                            part.bold ? <strong>{part.text}</strong> : part.text,
                          )}
                        </a>
                      ) : (
                        <span class="text-headings text-sm">
                          {splitBoldSegments(item.data.title).map((part) =>
                            part.bold ? (
                              <strong>{part.text}</strong>
                            ) : (
                              part.text
                            ),
                          )}
                        </span>
                      )}
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </Container>
    )
  }
  {
    config.sections.publication && selectedPublications.length > 0 && (
      <Container as="section" class="py-6">
        <div class="flex flex-col gap-5">
          <span class="text-headings text-xl font-semibold">
            Selected Publications
          </span>
          <ul class="flex flex-col gap-8">
            {selectedPublications.map((publication) => (
              <PublicationItem entry={publication} />
            ))}
          </ul>
        </div>
      </Container>
    )
  }
  {
    config.sections.workExperience && sortedJobs.length > 0 && (
      <Container as="section" class="py-6">
        <div class="flex flex-col gap-5">
          <span class="text-headings text-xl font-semibold">Work Experience</span>
          <ul class="flex flex-col gap-8">
            {sortedJobs.map((job) => (
              <WorkExperience entry={job} />
            ))}
          </ul>
        </div>
      </Container>
    )
  }
  {
    config.sections.talks && sortedTalks.length > 0 && (
      <Container as="section" class="py-6">
        <div class="flex flex-col gap-5">
          <span class="text-headings text-xl font-semibold">Speaking</span>
          <ul class="flex flex-col gap-8">
            {sortedTalks.map((talk) => (
              <Talk entry={talk} />
            ))}
          </ul>
        </div>
      </Container>
    )
  }
</BaseLayout>

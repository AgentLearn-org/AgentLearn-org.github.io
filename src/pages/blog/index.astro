---
import { getCollection, getEntry } from 'astro:content';
import Author from '@/components/ui/Author.astro';
import Container from '@/components/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { DEFAULT_CONFIGURATION } from '@/lib/constants';
import PostPreview from '@/components/ui/PostPreview.astro';

const entry = await getEntry('pages', 'blog');
const posts = await getCollection('posts');
const links = await getCollection('links');
const emailLink = links.find(
  (link) =>
    link.data.label.toLowerCase() === 'email' ||
    link.data.url.toLowerCase().startsWith('mailto:'),
);
const contactLinks = links.filter((link) => link !== emailLink);
---

<BaseLayout seo={entry.data.seo}>
  <Container as='section' class='py-6'>
    <Author
      {...DEFAULT_CONFIGURATION.author}
      emailLabel={emailLink?.data.name}
      emailUrl={emailLink?.data.url}
      contactLinks={contactLinks.map((link) => link.data)}
    />
  </Container>
  <Container as='section' class='py-6'>
    <div class="flex flex-col gap-6">
      <span class="text-headings text-xl font-semibold">Latest posts</span>
      <ul class="flex flex-col gap-3">
        {posts.map((post) => <PostPreview entry={post} />)}
      </ul>
    </div>
  </Container>
</BaseLayout>

---
import type { Publication } from '@/lib/data';

interface Props {
  entry: Publication;
}

const { entry } = Astro.props;

const normalizeName = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z\s]/g, '')
    .replace(/\s+/g, ' ')
    .trim();

const authorList = entry.authors
  .split(/\s+and\s+|,\s*/g)
  .map((author) => author.trim())
  .filter(Boolean)
  .map((author) => author.replace(/\*/g, '').trim());

const isSunghwanKim = (author: string) =>
  normalizeName(author) === 'sunghwan kim';

const visibleAuthors =
  authorList.length > 10 ? authorList.slice(0, 9) : authorList;
const hiddenAuthors = authorList.length > 10 ? authorList.slice(9) : [];

---

<li class="py-0.5">
  <div class="flex gap-5">
    <div class="relative min-w-28 shrink-0">
      <span class="text-muted-foreground text-sm font-semibold">
        {entry.conference ?? 'Publication'}
      </span>
    </div>
    <div class="flex flex-col gap-2">
      <span class="text-headings font-medium">{entry.title}</span>
      <span class="text-foreground text-sm">
        {visibleAuthors.map((author, index) => (
          <span>
            {index > 0 && ', '}
            {isSunghwanKim(author) ? <strong>{author}</strong> : author}
          </span>
        ))}
        {hiddenAuthors.length > 0 && (
          <>
            {visibleAuthors.length > 0 && ', '}
            <details class="inline">
              <summary class="inline list-none cursor-pointer text-muted-foreground hover:text-headings transition-colors">
                More..
              </summary>
              <span class="inline">
                {hiddenAuthors.map((author, index) => (
                  <span>
                    {index > 0 && ', '}
                    {isSunghwanKim(author) ? (
                      <strong>{author}</strong>
                    ) : (
                      author
                    )}
                  </span>
                ))}
              </span>
            </details>
          </>
        )}
      </span>
      {entry.info && (
        <p class="text-red-500 text-sm font-semibold">{entry.info}</p>
      )}
      <div class="flex flex-wrap items-center gap-3 text-sm">
        <a
          class="text-headings font-medium hover:text-headings/80 transition-colors inline-flex items-center gap-2 border border-border rounded-full px-3 py-1"
          rel="noopener noreferrer"
          target="_blank"
          href={entry.paperUrl}
        >
          Paper
        </a>
        {entry.codeUrl && (
          <a
            class="text-headings font-medium hover:text-headings/80 transition-colors inline-flex items-center gap-2 border border-border rounded-full px-3 py-1"
            rel="noopener noreferrer"
            target="_blank"
            href={entry.codeUrl}
          >
            Code
          </a>
        )}
      </div>
    </div>
  </div>
</li>
